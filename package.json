{
  "name": "clawverse",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "build": "turbo run build",
    "build:ws": "pnpm -r build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",

    "daemon:start": "pnpm --filter @clawverse/daemon start",
    "daemon:dev": "pnpm --filter @clawverse/daemon dev",
    "daemon:bootstrap": "bash tools/daemon/bootstrap.sh",
    "daemon:stop": "bash tools/daemon/stop-daemon.sh",

    "town:join": "bash tools/daemon/bootstrap.sh && pnpm soul:start && pnpm social:start && pnpm collab:start && pnpm life:start && pnpm storyteller:start && pnpm walk:start",
    "town:leave": "pnpm social:stop && pnpm collab:stop && pnpm life:stop && pnpm storyteller:stop && pnpm walk:stop && pnpm daemon:stop",

    "viewer:dev": "pnpm --filter @clawverse/town-viewer dev",
    "viewer:build": "pnpm --filter @clawverse/town-viewer build",

    "connector:report": "pnpm --filter @clawverse/connector-skill build && node apps/connector-skill/dist/index.js",

    "social:worker": "pnpm --filter @clawverse/connector-skill worker",
    "social:start": "bash tools/social/start-worker.sh",
    "social:stop": "bash tools/social/stop-worker.sh",

    "soul:worker": "pnpm --filter @clawverse/connector-skill soul",
    "soul:start": "bash tools/soul/start-soul-worker.sh",

    "collab:worker": "pnpm --filter @clawverse/connector-skill collab",
    "collab:start": "bash tools/collab/start-collab-worker.sh",
    "collab:stop": "bash tools/collab/stop-collab-worker.sh",

    "walk:worker": "pnpm --filter @clawverse/connector-skill walk",
    "walk:start": "bash tools/walk/start-walk-worker.sh",
    "walk:stop": "bash tools/walk/stop-walk-worker.sh",

    "life:worker": "pnpm --filter @clawverse/connector-skill life",
    "life:start": "bash tools/life/start-life-worker.sh",
    "life:stop": "bash tools/life/stop-life-worker.sh",

    "storyteller:worker": "pnpm --filter @clawverse/connector-skill storyteller",
    "storyteller:start": "bash tools/storyteller/start-worker.sh",
    "storyteller:stop": "bash tools/storyteller/stop-worker.sh",

    "evolve:propose": "node tools/evolution/propose.mjs",
    "evolve:evaluate": "node tools/evolution/evaluate.mjs",
    "evolve:decide": "node tools/evolution/decide.mjs",
    "evolve:rollout": "node tools/evolution/apply-rollout.mjs",
    "evolve:rollout-history": "node tools/evolution/rollout-history.mjs",
    "evolve:notify": "node tools/evolution/notify.mjs",
    "evolve:status": "node tools/evolution/status.mjs",
    "evolve:cycle": "node tools/evolution/cycle.mjs",
    "evolve:cron": "bash tools/evolution/schedule-cron.sh"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
