{
  "goal": "Increase task success while keeping latency/cost stable",
  "baseline": "baseline-v1",
  "candidate": "candidate-v2",
  "metrics": {
    "minSuccessLift": 0.03,
    "maxLatencyDeltaMs": 150,
    "maxTokenDelta": 300,
    "maxCostDeltaUsd": 0.02
  },
  "evaluation": {
    "includeSources": ["task-runtime", "manual"],
    "minSamplesBaseline": 5,
    "minSamplesCandidate": 5
  },
  "rollout": {
    "stage1": "10% traffic for 2 hours",
    "stage2": "50% traffic for 12 hours",
    "stage3": "100% traffic"
  },
  "rolloutPolicy": {
    "startRatio": 0.1,
    "stepUp": 0.2,
    "maxRatio": 1,
    "stepDownOnFail": 0.1
  },
  "notes": "Only evolve prompts/planner first. Do not auto-edit security boundaries."
}
